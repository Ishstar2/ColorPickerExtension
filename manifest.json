{
  "manifest_version": 3,
  "name": "Color Picker Extension",
  "version": "1.2",
  "description": "A color picker with palette history and exports",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "permissions": [
    "storage"
  ]
}
