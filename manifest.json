{
  "manifest_version": 3,
  "name": "Utility Hub Extension",
  "version": "2.1",
  "description": "All-in-one productivity suite featuring a color picker, word counter, and local AI text summarizer.",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "permissions": [
    "storage"
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+E",
        "mac": "Command+Shift+E"
      },
      "description": "Open Utility Hub Popup"
    }
  }
}
